# =====================================================================
#  Secrets des Edge Functions — CÔTÉ SERVEUR UNIQUEMENT.
#  Ne JAMAIS préfixer par VITE_ ni exposer ces valeurs au front-end.
#  Ne JAMAIS committer le fichier réel (.env) avec de vraies valeurs.
#
#  Cloudinary → Dashboard → Settings → API Keys.
# =====================================================================

CLOUDINARY_API_KEY=VOTRE_API_KEY
CLOUDINARY_API_SECRET=VOTRE_API_SECRET

# Dossier Cloudinary géré par l'app. Upload ET delete sont restreints à ce
# dossier (et ses sous-dossiers) : impossible de toucher des assets hors périmètre.
CLOUDINARY_FOLDER=products

# Sécurité : la fonction exige un utilisateur Supabase authentifié de rôle
# "admin" (app_metadata.role === "admin"). Laisser REQUIRE_AUTH=true en prod.
REQUIRE_AUTH=true

# Bypass d'auth pour TEST LOCAL UNIQUEMENT : nécessite LES DEUX marqueurs
# (REQUIRE_AUTH=false ET LOCAL_DEV=1). Ainsi un REQUIRE_AUTH=false déployé par
# erreur en prod reste sans effet. Voir docs/cloudinary-setup.md.
# LOCAL_DEV=1

# --- Notification WhatsApp (Edge Function notify-order) --------------
# Secret partagé avec le Database Webhook (en-tête x-webhook-secret).
ORDER_WEBHOOK_SECRET=un-secret-long-et-aleatoire
# API WhatsApp Business Cloud (Meta) — voir docs/whatsapp-setup.md.
WHATSAPP_TOKEN=VOTRE_TOKEN_META
WHATSAPP_PHONE_ID=VOTRE_PHONE_NUMBER_ID
# Numéro destinataire (équipe), format international SANS "+", ex. 2135XXXXXXXX
WHATSAPP_TEAM_TO=2135XXXXXXXX

# Note : SUPABASE_URL, SUPABASE_ANON_KEY et SUPABASE_SERVICE_ROLE_KEY sont
# injectés automatiquement par la plateforme dans les Edge Functions.
